{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Marks Amazing Subtitles",
  "version": "3.5.0",
  "identifier": "com.marks-amazing-subtitles",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "titleBarStyle": "Overlay",
        "decorations": true,
        "trafficLightPosition": {
          "x": 10,
          "y": 20
        },
        "height": 700,
        "width": 900,
        "acceptFirstMouse": true,
        "zoomHotkeysEnabled": true,
        "title": ""
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$DESKTOP/**",
          "$DOCUMENT/**",
          "$DOWNLOAD/**",
          "$RESOURCE/**"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "app",
      "deb",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/"
    ],
    "externalBin": [
      "binaries/ffmpeg"
    ],
    "macOS": {
      "minimumSystemVersion": "13.3"
    },
    "linux": {
      "deb": {
        "files": {
          "/opt/resolve/Fusion/Scripts/Utility/MarksAmazingSubs.lua": "resources/MarksAmazingSubs.lua",
          "/opt/resolve/Fusion/Scripts/Utility/MarksAmazingSubs": "resources/AutoSubs/"
        }
      }
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "createUpdaterArtifacts": false
  }
}